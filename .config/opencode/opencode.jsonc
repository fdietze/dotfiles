{
  "$schema": "https://opencode.ai/config.json",
  "model": "google/gemini-3.1-pro-preview",
  "autoupdate": false,
  "small_model": "google/gemini-2.5-flash-lite",
  "default_agent": "architect",
  "formatter": false,
  "agent": {
    "build": {
      // "model": "openrouter/google/gemini-3-pro-preview"
      // "model": "google/gemini-3-flash-preview"
      // "model": "openrouter/z-ai/glm-5"
      "model": "openai/gpt-5.3-codex",
      // "model": "google/gemini-3.1-pro-preview"
      // "model": "anthropic/claude-sonnet-4-6"
    },
    "explore": {
      // "model": "google/gemini-3.1-pro-preview"
      "model": "google/gemini-3-flash-preview"
    },
    "plan": {
      // "model": "anthropic/claude-opus-4-6",
      "model": "openai/gpt-5.3-codex",
      // "model": "google/gemini-3.1-pro-preview",
      "prompt": "{file:./prompts/plan.md}",
    },
  },
  "plugin": [
    "@tarquinen/opencode-dcp@latest"
  ],
  "experimental": {
    "batch_tool": true
  },
  "compaction": {
    "auto": false,
  },
  "provider": {
    "openrouter": {},
    "google": {
      "models": {
        "gemini-2.5-pro": {
          // "thinkingConfig": {
          //   "thinkingBudget": 4000
          // }
        }
      }
    }
  },
  "permission": {
    "lsp": "allow",
    "read": {
      ".envrc": "allow",
      ".envrc.example": "allow",
      ".envrc.local": "deny",
    },
    "bash": {
      "*": "ask",
      "pwd": "allow",
      "rg *": "allow",
      "ps *": "allow",
      "ldd *": "allow",
      "xargs *": "allow",
      "strings *": "allow",
      "grep *": "allow",
      "wc *": "allow",
      "find *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "cat *": "allow",
      "touch *": "allow",
      "ls *": "allow",
      "echo *": "allow",
      "mkdir *": "allow",
      "git status *": "allow",
      "git diff *": "allow",
      "git show *": "allow",
      "git log *": "allow",
      "just *": "allow",
      "nix *": "allow",
      "docker *": "allow",
      "true *": "allow",
      "devbox install": "allow",
      "cargo *": "allow",
      "npm run typecheck": "allow",
      "npm run lint": "allow",
      "npm run test:e2e": "allow",
      "npm run test:unit": "allow",
      "npx playwright test": "allow",
      "pytest *": "allow",
      "ty *": "allow",
      "ruff *": "allow",
      "time *": "allow",
      "timeout *": "allow",
      "jq *": "allow",
      "chmod *": "allow",
    }
  }
}
