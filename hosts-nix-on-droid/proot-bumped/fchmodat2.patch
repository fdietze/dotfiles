--- a/src/syscall/seccomp.c	2026-06-24 00:03:57.657240840 +0400
+++ b/src/syscall/seccomp.c	2026-06-24 00:04:08.236198653 +0400
@@ -348,6 +348,7 @@
 	{ PR_faccessat2,	FILTER_SYSEXIT },
 	{ PR_fchdir,		FILTER_SYSEXIT },
 	{ PR_fchmodat,		0 },
+	{ PR_fchmodat2,		0 },
 	{ PR_fchownat,		0 },
 	{ PR_fstatat64,		0 },
 	{ PR_futimesat,		0 },
