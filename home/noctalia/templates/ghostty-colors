# pi-terminal-theme "terminal-tinted" custom palette slots 16..23 (full slot->token
# rationale in kitty-colors.conf). Status backgrounds 17/18/19/21 are the MD3
# surface_container_high stamped with a fixed semantic hue (set_saturation 30 |
# set_hue H) for 17/18/19/21 (full rationale in kitty-colors.conf): the MD3 *_container
# tokens vary too much in lightness across schemes (vivid for base16, near-black for
# wallpaper schemes), so they're replaced by a dim mode-correct surface + fixed hue.
# 22 uses on_surface so the title stays readable on every tint in both modes.
palette = 16={{colors.surface_container_high.default.hex}}
palette = 17={{colors.surface_container_high.default.hex | set_saturation 30 | set_hue 2}}
palette = 18={{colors.surface_container_high.default.hex | set_saturation 30 | set_hue 135}}
palette = 19={{colors.surface_container_high.default.hex | set_saturation 30 | set_hue 222}}
palette = 20={{colors.surface_container.default.hex}}
palette = 21={{colors.surface_container_high.default.hex | set_saturation 30 | set_hue 300}}
palette = 22={{colors.on_surface.default.hex}}
palette = 23={{colors.on_surface_variant.default.hex}}
