# pi-terminal-theme "terminal-tinted" custom palette slots 16..23 (full slot->token
# rationale in kitty-colors.conf). Status backgrounds 17/18/19/21 are the MD3
# *_container tokens with `desaturate 35` (full rationale in kitty-colors.conf):
# base16's pastel accents make vivid containers, so desaturate tames them; darken is
# avoided because it blacks out wallpaper schemes' already-dark containers. 22 uses
# on_surface so the title stays readable on every container in both modes.
palette = 16={{colors.surface_container_high.default.hex}}
palette = 17={{colors.error_container.default.hex | desaturate 35}}
palette = 18={{colors.primary_container.default.hex | desaturate 35}}
palette = 19={{colors.tertiary_container.default.hex | desaturate 35}}
palette = 20={{colors.surface_container.default.hex}}
palette = 21={{colors.secondary_container.default.hex | desaturate 35}}
palette = 22={{colors.on_surface.default.hex}}
palette = 23={{colors.on_surface_variant.default.hex}}
