{
  "keyboard.dispatch": "keyCode",
  "editor.suggestSelection": "first",
  "vsintellicode.modify.editor.suggestSelection": "automaticallyOverrodeDefaultValue",
  "workbench.colorTheme": "Tokyo Night Storm",
  "workbench.preferredLightColorTheme": "Catppuccin Latte",
  "workbench.preferredDarkColorTheme": "Tokyo Night Storm",
  "editor.formatOnSave": true,
  "vim.leader": " ",
  "vim.useSystemClipboard": true,
  // "vim.normalModeKeyBindingsNonRecursive": [
  //   {
  //     "before": ["ä"],
  //     "commands": [":q"]
  //   },
  //   {
  //     "before": ["ö"],
  //     "commands": [":w"]
  //   },
  //   {
  //     "before": ["ü"],
  //     "commands": ["workbench.action.closeActiveEditor"]
  //   },
  //   {
  //     "before": ["l"],
  //     "commands": ["workbench.action.nextEditor"]
  //   },
  //   {
  //     "before": ["L"],
  //     "commands": ["workbench.action.previousEditor"]
  //   }
  // ],
  "editor.formatOnPaste": true,
  "editor.inlineSuggest.enabled": true,
  "window.zoomLevel": -1,
  "editor.minimap.showSlider": "always",
  "editor.wordWrap": "on",
  "editor.wrappingIndent": "indent",
  "editor.fontFamily": "monospace",
  "workbench.editor.highlightModifiedTabs": true,
  "[python]": {
    "editor.formatOnType": true,
    "editor.defaultFormatter": "charliermarsh.ruff"
  },
  "files.watcherExclude": {
    "**/.bloop": true,
    "**/.metals": true,
    "**/.ammonite": true,
    "**/out": true
  },
  "metals.enableIndentOnPaste": true,
  "window.titleBarStyle": "custom",
  "window.customMenuBarAltFocus": false,
  "window.enableMenuBarMnemonics": false,
  "metals.serverVersion": "1.2.2+117-8cc7a42f-SNAPSHOT",
  "window.menuBarVisibility": "compact",
  "breadcrumbs.enabled": false,
  "editor.autoClosingBrackets": "never",
  "editor.cursorBlinking": "solid",
  "update.mode": "none",
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.fontSize": 12,
  "cursor.cpp.disabledLanguages": ["plaintext", "markdown", "scminput"],
  "[rust]": {
    "editor.defaultFormatter": "rust-lang.rust-analyzer"
  },
  "[kotlin]": {
    "editor.defaultFormatter": "fwcd.kotlin"
  },
  "cursor.diffs.useCharacterLevelDiffs": true,
  "rust-analyzer.cargo.targetDir": true,
  "rust-analyzer.check.command": "clippy",
  "cursor.cpp.enablePartialAccepts": true,
  "errorLens.messageBackgroundMode": "none",
  "extensions.experimental.affinity": {
    "asvetliakov.vscode-neovim": 1
  },
  "editor.minimap.enabled": false,
  "cursor.composer.shouldChimeAfterChatFinishes": true,
  "cursor.terminal.usePreviewBox": true,
  "cursor.composer.shouldAllowCustomModes": true,
  "git.openRepositoryInParentFolders": "never",
  "terminal.integrated.scrollback": 10000,
  "terminal.integrated.shellIntegration.enabled": true,
  // "terminal.integrated.defaultProfile.linux": "bash (2)",
  "diffEditor.maxComputationTime": 0,
  "[dart]": {
    "editor.formatOnSave": true,
    "editor.formatOnType": true,
    "editor.rulers": [80],
    "editor.selectionHighlight": false,
    "editor.tabCompletion": "onlySnippets",
    "editor.wordBasedSuggestions": "off"
  },
  "dart.lineLength": 140,
  "terminal.integrated.fontSize": 13,
  "window.autoDetectColorScheme": true,
  "kilo-code.allowedCommands": [
    "git log",
    "git diff",
    "git show",
    "just",
    "npm run",
    "npx playwright",
    "grep",
    "head",
    "tail",
    "node",
    "npm test",
    "ls",
    "uv add",
    "pytest",
    "cargo",
    "curl",
    "cd",
    "timeout",
    "true",
    "mkdir",
    "echo",
    "git status",
    "ps",
    "nix",
    "nix-build",
    "find",
    "xargs",
    "which",
    "git clone",
    "cat",
    "sort",
    "wget",
    "jq",
    "rg",
    "sed",
    "wc",
    "readlink",
    "devbox",
    "chmod",
    "flutter",
    "pnpm",
    "grpcurl",
    "npx tsc",
    "./scripts/generate-migration-atlas",
    "FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099",
    "FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099 cargo",
    "FIREBASE_AUTH_EMULATOR_HOST=\"127.0.0.1:9099\" cargo test --test api_auth_test test_protected_route_accepts_valid_token -- --nocapture",
    "xxd",
    "du",
    "strings",
    "touch",
    "RUST_BACKTRACE=1 cargo run --release 2>&1",
    "RUST_BACKTRACE=1",
    "tail -80",
    "RUST_BACKTRACE=1 cargo",
    "RUST_BACKTRACE=1 cargo run",
    "let",
    "for",
    "done",
    "do",
    "( cargo test -- --ignored",
    "cargo clippy --all-targets",
    "( cargo test test_training_stability -- --ignored",
    "python3 debug_deinterlace.py",
    "RUST_LOG=info timeout",
    "time",
    "RUST_LOG=debug",
    "( cd sdk-rust",
    "ssh lambda",
    "scp experiment-22-h100.py lambda:",
    "scp",
    "ssh",
    "./python-gpu"
  ],
  "kilo-code.deniedCommands": [],
  "workbench.editor.enablePreview": false,
  "python.defaultInterpreterPath": "/etc/profiles/per-user/felix/bin/python",
  "workbench.secondarySideBar.defaultVisibility": "hidden",
  "github.copilot.nextEditSuggestions.enabled": true,
  "github.copilot.enable": {
    "*": false,
    "plaintext": false,
    "markdown": false,
    "scminput": false
  }
}
