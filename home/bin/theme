#!/usr/bin/env bash
set -eo pipefail

OLDTHEME=$(cat "$HOME/.theme" || echo dark)
# light or dark
THEME=${1:-$OLDTHEME}

case $THEME in
light | dark) ;;
*)
  echo "usage: theme <light|dark>"
  exit 1
  ;;
esac

# case $THEME in
# light) sudo /nix/var/nix/profiles/system/specialisation/light/bin/switch-to-configuration switch ;;
# dark) sudo /nix/var/nix/profiles/system/bin/switch-to-configuration switch ;;
# esac

#load env vars with colors
source "$HOME/bin/theme-env" # (gf to open)

# echo "nvim..."
nvr --serverlist | while read -r nvim_instance; do
  nvr --servername "$nvim_instance" -c "set background=$THEME" -c "colorscheme $VIM_COLORSCHEME" &
done

